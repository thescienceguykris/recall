# Required for the default Docker Compose setup.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=

# Local defaults. Leave these unset unless you want to override them.
STORE_TYPE=json
AUTH_MODE=none

# Postgres + OIDC multi-user setup.
# Set STORE_TYPE=postgres and AUTH_MODE=oidc, then run:
# docker compose --profile postgres up --build
POSTGRES_PASSWORD=recall
DATABASE_URL=postgres://recall:recall@postgres:5432/recall?sslmode=disable
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=
SESSION_SECRET=
AUTH_ALLOWED_EMAILS=
AUTH_ALLOWED_DOMAINS=

# Optional downloader overrides.
YTDLP_EXTRA_ARGS=
